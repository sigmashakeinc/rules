# solidjs_write_safety.rules
# Technology: solidjs | Capability: write

rule solidjs-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "innerHTML={"
  MESSAGE "Blocked an unsafe pattern in solidjs. Use the recommended best practices for 2025/2026."
}

rule solidjs-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "useRoutes"
  MESSAGE "You are using an outdated API for solidjs. Please upgrade to the newer API."
}
