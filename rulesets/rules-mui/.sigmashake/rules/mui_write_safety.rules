# mui_write_safety.rules
# Technology: mui | Capability: write

rule mui-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "dangerouslySetInnerHTML"
  MESSAGE "Blocked an unsafe pattern in mui. Use the recommended best practices for 2025/2026."
}

rule mui-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "makeStyles"
  MESSAGE "You are using an outdated API for mui. Please upgrade to the newer API."
}
