# transformers_write_safety.rules
# Technology: transformers | Capability: write

rule transformers-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "trust_remote_code=True"
  MESSAGE "Blocked an unsafe pattern in transformers. Use the recommended best practices for 2025/2026."
}

rule transformers-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "AutoModelWithLMHead"
  MESSAGE "You are using an outdated API for transformers. Please upgrade to the newer API."
}
