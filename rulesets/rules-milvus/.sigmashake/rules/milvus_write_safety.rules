# milvus_write_safety.rules
# Technology: milvus | Capability: write

rule milvus-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "root:Milvus"
  MESSAGE "Blocked an unsafe pattern in milvus. Use the recommended best practices for 2025/2026."
}

rule milvus-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "MilvusDocumentStore"
  MESSAGE "You are using an outdated API for milvus. Please upgrade to the newer API."
}
