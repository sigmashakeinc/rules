# prometheus_write_safety.rules
# Technology: prometheus | Capability: write

rule prometheus-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "remote_write"
  MESSAGE "Blocked an unsafe pattern in prometheus. Use the recommended best practices for 2025/2026."
}

rule prometheus-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "rule_files"
  MESSAGE "You are using an outdated API for prometheus. Please upgrade to the newer API."
}
