# fs_read_secrets.rules — Block access to secret files and prevent hardcoded credentials.
# Technology: fs | Capability: read
# Covers: .env files, private keys, cloud/AI credential files, and hardcoded tokens in source.

rule no-read-env-files {
  enabled true
  priority 95
  severity error
  DENY read
  IF path EQUALS ".env"
  OR path ENDS_WITH "/.env"
  OR path REGEX "\\.env\\."
  OR path ENDS_WITH "/.env.local"
  OR path ENDS_WITH "/.env.production"
  OR path ENDS_WITH "/.env.staging"
  MESSAGE "Reading .env files is blocked. Secret values should be accessed via environment variables at runtime, not read directly from disk by agents."
}

rule no-read-key-files {
  enabled true
  priority 95
  severity error
  DENY read
  IF path ENDS_WITH ".pem"
  OR path ENDS_WITH ".key"
  OR path ENDS_WITH "_rsa"
  OR path ENDS_WITH "_ed25519"
  OR path ENDS_WITH "_ecdsa"
  OR path REGEX ".*credentials.*\\.json$"
  OR path REGEX ".*credentials.*\\.yaml$"
  OR path ENDS_WITH "/credentials"
  MESSAGE "Private key and credential files must not be read by agents. If a key needs to be used, reference it by path in a config — never read its contents."
}

rule no-read-additional-key-files {
  enabled true
  priority 95
  severity error
  DENY read
  IF path ENDS_WITH ".ppk"
  OR path ENDS_WITH ".p12"
  OR path ENDS_WITH ".pfx"
  OR path ENDS_WITH ".jks"
  OR path ENDS_WITH ".keystore"
  OR path ENDS_WITH "/id_dsa"
  OR path ENDS_WITH "/id_ecdsa"
  OR path ENDS_WITH "/known_hosts"
  OR path REGEX ".*/\\.ssh/(?!config$).+"
  MESSAGE "PKCS#12/PuTTY/Java keystores and SSH key material contain private keys. RISK: reading them loads key bytes into agent context. FIX: reference the keystore by path in config and load it at runtime."
}

rule no-read-cloud-credential-files {
  enabled true
  priority 95
  severity error
  DENY read
  IF path REGEX ".*/\\.aws/credentials$"
  OR path REGEX ".*/\\.aws/config$"
  OR path REGEX ".*/\\.config/gcloud/application_default_credentials\\.json$"
  OR path REGEX ".*/\\.config/gcloud/legacy_credentials/.*"
  OR path REGEX ".*/\\.kube/config$"
  OR path ENDS_WITH "/kubeconfig"
  OR path REGEX ".*service[_-]account.*\\.json$"
  OR path REGEX ".*/\\.azure/.*"
  OR path REGEX ".*/\\.docker/config\\.json$"
  MESSAGE "Cloud CLI credential stores (AWS, GCP, Azure, kubeconfig, docker config) carry session tokens and service-account keys. FIX: never inline these into source or context; authenticate via the CLI/SDK at runtime."
}

rule no-cat-secret-files {
  enabled true
  priority 95
  severity error
  DENY execution
  IF command CONTAINS "cat .env"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*\\.env"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*credentials"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*\\.pem"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*\\.key"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*/\\.aws/"
  OR command REGEX "(cat|less|more|head|tail)\\s+\\S*/\\.ssh/id_"
  MESSAGE "Do not dump secret files to stdout via shell commands. Use environment variables or a secrets manager at runtime."
}

rule no-hardcode-secrets {
  enabled true
  priority 90
  severity error
  LOG write
  IF path GLOB "**/*.ts" AND content LINE_REGEX "(password|api_key|apikey|secret|token|private_key)\\s*[:=]\\s*['\"][^'\"]{8,}"
  OR path GLOB "**/*.js" AND content LINE_REGEX "(password|api_key|apikey|secret|token|private_key)\\s*[:=]\\s*['\"][^'\"]{8,}"
  OR path GLOB "**/*.py" AND content LINE_REGEX "(password|api_key|apikey|secret|token|private_key)\\s*[:=]\\s*['\"][^'\"]{8,}"
  OR path GLOB "**/*.go" AND content LINE_REGEX "(password|api_key|apikey|secret|token|private_key)\\s*:?=\\s*\"[^\"]{8,}\""
  MESSAGE "Possible hardcoded secret detected. Store credentials in environment variables or a secrets manager, never in source code."
}

rule no-hardcoded-aws-access-key {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "AKIA[0-9A-Z]{16}"
  OR path GLOB "**/*" AND content LINE_REGEX "ASIA[0-9A-Z]{16}"
  MESSAGE "AWS access key detected (AKIA/ASIA prefix). RISK: 2025 credential-harvesting campaigns showed AWS keys in public repos were abused within minutes. FIX: rotate the key at IAM immediately and load via AWS SDK default credential chain (env/role)."
}

rule no-hardcoded-github-token {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "gh[pousr]_[A-Za-z0-9]{36,}"
  OR path GLOB "**/*" AND content LINE_REGEX "github_pat_[A-Za-z0-9_]{82}"
  MESSAGE "GitHub token detected (ghp_/gho_/ghu_/ghs_/ghr_ or github_pat_). RISK: Snyk's 2025 report found 96% of leaked GitHub tokens had write scope enabling supply-chain attacks. FIX: revoke at github.com/settings/tokens and use GITHUB_TOKEN env var or a GitHub App."
}

rule no-hardcoded-openai-key {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "sk-proj-[A-Za-z0-9_-]{40,}"
  OR path GLOB "**/*" AND content LINE_REGEX "sk-[A-Za-z0-9]{48}"
  MESSAGE "OpenAI API key detected (sk- or sk-proj- prefix). RISK: AI provider keys were the fastest-growing leak category in 2025 (+81% YoY). FIX: revoke at platform.openai.com/api-keys and read from OPENAI_API_KEY at runtime."
}

rule no-hardcoded-anthropic-key {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "sk-ant-(api|admin)\\d{2}-[A-Za-z0-9_-]{80,}"
  MESSAGE "Anthropic API key detected (sk-ant-api/sk-ant-admin prefix). RISK: CVE-2025-59536 showed Claude Code keys exfiltrated via malicious project files. FIX: revoke at console.anthropic.com and read from ANTHROPIC_API_KEY env var."
}

rule no-hardcoded-ai-provider-token {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "hf_[A-Za-z0-9]{34,}"
  OR path GLOB "**/*" AND content LINE_REGEX "r8_[A-Za-z0-9]{37,}"
  OR path GLOB "**/*" AND content LINE_REGEX "gsk_[A-Za-z0-9]{50,}"
  MESSAGE "AI platform token detected (Hugging Face hf_, Replicate r8_, or Groq gsk_). RISK: Hugging Face tokens were the most-leaked AI credential type in 2025. FIX: revoke on the provider dashboard and load from HF_TOKEN/REPLICATE_API_TOKEN/GROQ_API_KEY env vars."
}

rule no-hardcoded-stripe-key {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "(sk|rk)_live_[0-9a-zA-Z]{20,}"
  MESSAGE "Stripe live secret/restricted key detected (sk_live_/rk_live_). RISK: live keys authorize real charges and payouts. FIX: roll the key in Stripe Dashboard and load from STRIPE_SECRET_KEY env var; use sk_test_ keys for examples."
}

rule no-hardcoded-slack-token {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "xox[abporsu]-\\d{10,}-\\d{10,}-[A-Za-z0-9-]{20,}"
  OR path GLOB "**/*" AND content LINE_REGEX "https://hooks\\.slack\\.com/services/T[A-Z0-9]{8,}/B[A-Z0-9]{8,}/[A-Za-z0-9]{24}"
  MESSAGE "Slack token or incoming webhook URL detected. RISK: leaked webhooks allow spoofed messages; bot tokens grant workspace read/write. FIX: revoke at api.slack.com/apps and read from SLACK_BOT_TOKEN env var."
}

rule no-hardcoded-google-api-key {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "AIza[0-9A-Za-z_\\-]{35}"
  MESSAGE "Google API key detected (AIza prefix). RISK: unrestricted Google keys allow billed Maps/Translate/GenAI calls against the owner's quota. FIX: restrict the key to specific APIs/referrers in GCP console or rotate and load from env var."
}

rule no-pem-private-key-in-source {
  enabled true
  priority 95
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "-----BEGIN RSA PRIVATE KEY-----"
  OR path GLOB "**/*" AND content CONTAINS "-----BEGIN EC PRIVATE KEY-----"
  OR path GLOB "**/*" AND content CONTAINS "-----BEGIN DSA PRIVATE KEY-----"
  OR path GLOB "**/*" AND content CONTAINS "-----BEGIN OPENSSH PRIVATE KEY-----"
  OR path GLOB "**/*" AND content CONTAINS "-----BEGIN PGP PRIVATE KEY BLOCK-----"
  OR path GLOB "**/*" AND content CONTAINS "-----BEGIN PRIVATE KEY-----"
  MESSAGE "PEM-encoded private key material detected in source. RISK: inline private keys cannot be rotated without a code deploy and will be indexed by GitHub secret scanning. FIX: remove, rotate the key, and load from a secrets manager or file path outside source control."
}

rule no-db-url-with-password {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content LINE_REGEX "(postgres|postgresql|mysql|mongodb|redis|amqp)(\\+srv)?://[A-Za-z0-9._%+-]+:[^@\\s\"'<>]{3,}@"
  MESSAGE "Database connection string with embedded password detected. RISK: URL-embedded passwords appear in logs, proxies, and error traces. FIX: split credentials into DB_PASSWORD env var and reference via config; the MongoDB/Postgres drivers all accept separate user/password fields."
}

rule no-npmrc-auth-token {
  enabled true
  priority 90
  severity error
  DENY write
  IF path ENDS_WITH ".npmrc" AND content LINE_REGEX "_authToken\\s*=\\s*[A-Za-z0-9_-]{8,}"
  OR path ENDS_WITH ".npmrc" AND content LINE_REGEX "_password\\s*=\\s*[A-Za-z0-9+/=]{8,}"
  OR path ENDS_WITH ".yarnrc.yml" AND content LINE_REGEX "npmAuthToken:\\s*[A-Za-z0-9_-]{8,}"
  MESSAGE "npm/yarn registry auth token committed in .npmrc/.yarnrc.yml. RISK: committed npm tokens enable malicious publishes under your scope (2024/2025 supply-chain attacks). FIX: replace literal with \\${NPM_TOKEN} and set the env var in CI only."
}

rule no-mcp-config-hardcoded-key {
  enabled true
  priority 90
  severity error
  DENY write
  IF path ENDS_WITH ".mcp.json" AND content LINE_REGEX "\"(api[_-]?key|token|authorization|bearer)\"\\s*:\\s*\"[A-Za-z0-9_-]{16,}\""
  OR path ENDS_WITH "mcp.json" AND content LINE_REGEX "\"(api[_-]?key|token|authorization|bearer)\"\\s*:\\s*\"[A-Za-z0-9_-]{16,}\""
  OR path REGEX ".*/\\.claude/settings\\.(json|local\\.json)$" AND content LINE_REGEX "\"(api[_-]?key|token|authorization|bearer)\"\\s*:\\s*\"[A-Za-z0-9_-]{16,}\""
  MESSAGE "Hardcoded API key in MCP server / Claude settings config. RISK: CVE-2025-59536 and the 2025 GitGuardian MCP study found 24k+ secrets in public MCP configs. FIX: use \\${ENV_VAR} placeholder in the config and set the env var in your shell profile."
}

rule no-write-dotenv-file {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path EQUALS ".env"
  OR path ENDS_WITH "/.env"
  OR path ENDS_WITH "/.env.local"
  OR path ENDS_WITH "/.env.production"
  MESSAGE "Writing to a .env file. RISK: agent-written .env files are a common vector for committing real secrets (missing .gitignore entry). FIX: ensure .env is in .gitignore and prefer a .env.example template with placeholder values."
}

rule no-hardcoded-jwt-token {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content LINE_REGEX "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}"
  MESSAGE "JWT detected in source (three base64url segments). RISK: even expired JWTs can leak user IDs, scopes, and signing-algorithm hints useful for forgery. FIX: mint JWTs at runtime and pass via env/secret manager; use a placeholder in tests."
}

rule no-basic-auth-hardcoded {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content LINE_REGEX "[Aa]uthorization['\"]?\\s*[:=]\\s*['\"]?Basic\\s+[A-Za-z0-9+/]{16,}={0,2}"
  MESSAGE "Hardcoded HTTP Basic auth header detected. RISK: base64 is reversible — the cleartext user:password will be extracted in seconds. FIX: build the header at runtime from env-var credentials."
}
