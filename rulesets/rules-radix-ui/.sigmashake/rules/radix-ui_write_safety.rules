# radix-ui_write_safety.rules
# Technology: radix-ui | Capability: write

rule radix-ui-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "dangerouslySetInnerHTML"
  MESSAGE "Blocked an unsafe pattern in radix-ui. Use the recommended best practices for 2025/2026."
}

rule radix-ui-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "CollapsibleState"
  MESSAGE "You are using an outdated API for radix-ui. Please upgrade to the newer API."
}
