# webpack_write_safety.rules
# Technology: webpack | Capability: write

rule webpack-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "eval-source-map"
  MESSAGE "Blocked an unsafe pattern in webpack. Use the recommended best practices for 2025/2026."
}

rule webpack-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "optimization.noEmitOnErrors"
  MESSAGE "You are using an outdated API for webpack. Please upgrade to the newer API."
}
