# qt_write_safety.rules
# Technology: qt | Capability: write

rule qt-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "QProcess::start"
  MESSAGE "Blocked an unsafe pattern in qt. Use the recommended best practices for 2025/2026."
}

rule qt-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "QTextCodec"
  MESSAGE "You are using an outdated API for qt. Please upgrade to the newer API."
}
