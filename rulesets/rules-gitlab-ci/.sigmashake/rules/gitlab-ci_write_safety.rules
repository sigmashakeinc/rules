# gitlab-ci_write_safety.rules
# Technology: gitlab-ci | Capability: write

rule gitlab-ci-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "tags:"
  MESSAGE "Blocked an unsafe pattern in gitlab-ci. Use the recommended best practices for 2025/2026."
}

rule gitlab-ci-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "only:"
  MESSAGE "You are using an outdated API for gitlab-ci. Please upgrade to the newer API."
}
