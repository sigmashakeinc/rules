# scipy_write_safety.rules
# Technology: scipy | Capability: write

rule scipy-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "scipy.weave"
  MESSAGE "Blocked an unsafe pattern in scipy. Use the recommended best practices for 2025/2026."
}

rule scipy-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "scipy.misc"
  MESSAGE "You are using an outdated API for scipy. Please upgrade to the newer API."
}
