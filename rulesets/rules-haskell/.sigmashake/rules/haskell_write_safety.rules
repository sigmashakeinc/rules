# haskell_write_safety.rules
# Technology: haskell | Capability: write

rule haskell-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "unsafePerformIO"
  MESSAGE "Blocked an unsafe pattern in haskell. Use the recommended best practices for 2025/2026."
}

rule haskell-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "fail"
  MESSAGE "You are using an outdated API for haskell. Please upgrade to the newer API."
}
