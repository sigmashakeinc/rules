[13.723104, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mThe edit is being blocked by a security hook\u001b[1Cconfigured\u001b[1Cin\u001b[1Cthis\u001b[1Cproject.\u001b[1CThe\u001b[1C\u001b[38;5;153mssg hook eval\u001b[1C\u001b[39mhook\u001b[1Chas\u001b[1Ca\u001b[1Crule\u001b[1Cthat\u001b[1Cprevents\u001b[1Chardcoded\u001b[1Cpasswords\u001b[1Cfrom\u001b[1Cbeing\u001b[1Cadded\u001b[1Cto\r\u001b[2C\u001b[1Bsource\u001b[1Ccode.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[13.931893, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  This is actually good security practice — the project is configured to reject commits with hardcoded credentials and recommends using environment variables or a secrets       \r\u001b[1B  manager\u001b[1Cinstead.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.158755, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  If you want to bypass this security check, you can:                                                                                                                            \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.336229, "o", "\u001b]0;⠐ Replace TODO in app.ts with constant\u0007"]
[14.352343, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. Disable or modify the hook rules in \u001b[38;5;153mssg hook eval\u001b[39m                                                                                                              \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.752723, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A2.\u001b[1CUse\u001b[1Cthe\u001b[1C\u001b[38;5;153m--no-verify\u001b[1C\u001b[39mflag\u001b[1Cif\u001b[1Cmaking\u001b[1Ca\u001b[1Cgit\u001b[1Ccommit\u001b[1C(though\u001b[1CI'd\u001b[1Cneed\u001b[1Cyour\u001b[1Cconfirmation\u001b[1Cfor\u001b[1Cthat)\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[14.776079, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[8A1.\u001b[1CDisable\u001b[1Cor\u001b[1Cmodify\u001b[1Cthe\u001b[1Chook\u001b[1Crules\u001b[1Cin\u001b[1C\u001b[38;5;153mssg hook eval\r\u001b[2C\u001b[1B\u001b[39m2\u001b[2CUse th\u001b[2C\u001b[38;5;153m--no-verify\u001b[39m flag if making a git commit (though I'd need\u001b[1Cyour\u001b[1Cconfirmation\u001b[1Cfor\u001b[1Cthat)\r\u001b[2C\u001b[1B  \u001b[1C   \u001b[1C   \u001b[1C           \u001b[1C    \u001b[1C  \u001b[1C      \u001b[1C \u001b[1C   \u001b[1C      \u001b[1C       \u001b[1C   \u001b[1C    \u001b[1C    \u001b[1C            \u001b[1C   \u001b[1C     \r\u001b[2C\u001b[1BWould\u001b[1Cyou\u001b[1Clike\u001b[1Cme\u001b[1Cto\u001b[1Cmake\u001b[1Cthe\u001b[1Cchange\u001b[1Cdespite\u001b[1Cthe\u001b[1Csecurity\u001b[1Ccheck,\u001b[1Cor\u001b[1Cwould\u001b[1Cyou\u001b[1Cprefer\u001b[1Cto\u001b[1Caddress\u001b[1Cthe\u001b[1Csecurity\u001b[1Crule\u001b[1Cfirst?\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;174m✻\u001b[39m \u001b[38;5;174mPropagating… \r\u001b[1B\u001b[39m                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u0