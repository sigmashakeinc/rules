# storybook_write_safety.rules
# Technology: storybook | Capability: write

rule storybook-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "dangerouslySetInnerHTML"
  MESSAGE "Blocked an unsafe pattern in storybook. Use the recommended best practices for 2025/2026."
}

rule storybook-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "storiesOf("
  MESSAGE "You are using an outdated API for storybook. Please upgrade to the newer API."
}
