# sequelize_write_safety.rules
# Technology: sequelize | Capability: write

rule sequelize-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "Sequelize.literal"
  MESSAGE "Blocked an unsafe pattern in sequelize. Use the recommended best practices for 2025/2026."
}

rule sequelize-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Model.query"
  MESSAGE "You are using an outdated API for sequelize. Please upgrade to the newer API."
}
