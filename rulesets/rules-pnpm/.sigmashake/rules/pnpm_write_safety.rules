# pnpm_write_safety.rules — Enforce safe package authoring for pnpm projects.
# Technology: pnpm | Capability: write
# Covers: lockfile, version pins, .pnpmfile.cjs hooks, overrides, .npmrc tokens.

rule no-edit-pnpm-lockfile {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS "pnpm-lock.yaml"
  OR path ENDS_WITH "/pnpm-lock.yaml"
  MESSAGE "pnpm-lock.yaml must not be hand-edited. It is machine-generated by 'pnpm install'. Manual edits corrupt integrity hashes and can silently break the dependency graph."
}

rule no-caret-tilde-pnpm {
  enabled true
  priority 85
  severity error
  DENY write
  IF path EQUALS "package.json" AND content LINE_REGEX "\"[\\^~][0-9]"
  OR path GLOB "**/package.json" AND content LINE_REGEX ": *\"[\\^~][0-9]"
  MESSAGE "Caret (^) and tilde (~) version ranges produce non-reproducible installs. Use exact version pins to ensure every 'pnpm install' resolves identically."
}

rule ask-pnpmfile-hooks {
  enabled true
  priority 85
  severity warning
  LOG write
  IF path EQUALS ".pnpmfile.cjs"
  OR path ENDS_WITH "/.pnpmfile.cjs"
  MESSAGE ".pnpmfile.cjs executes JavaScript code during every 'pnpm install'. It can silently modify dependency resolutions across the entire project without explicit user action."
}

rule ask-pnpm-overrides {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path EQUALS "package.json" AND content CONTAINS "\"overrides\""
  OR path GLOB "**/package.json" AND content CONTAINS "\"overrides\""
  MESSAGE "pnpm overrides silently replace transitive dependency versions across the entire tree. Incorrect overrides can mask security vulnerabilities or introduce incompatible versions."
}

rule no-npmrc-token-pnpm {
  enabled true
  priority 95
  severity error
  DENY write
  IF path EQUALS ".npmrc" AND content LINE_REGEX "_authToken\\s*="
  OR path GLOB "**/.npmrc" AND content LINE_REGEX "_authToken\\s*="
  MESSAGE "Hardcoded npm auth token in .npmrc exposes registry credentials in source control. Use environment variable substitution: //registry.npmjs.org/:_authToken=${NPM_TOKEN}"
}
