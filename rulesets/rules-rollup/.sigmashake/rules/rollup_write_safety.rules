# rollup_write_safety.rules
# Technology: rollup | Capability: write

rule rollup-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "eval"
  MESSAGE "Blocked an unsafe pattern in rollup. Use the recommended best practices for 2025/2026."
}

rule rollup-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "rollup-plugin-babel"
  MESSAGE "You are using an outdated API for rollup. Please upgrade to the newer API."
}
