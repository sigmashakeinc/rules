# splunk_write_safety.rules
# Technology: splunk | Capability: write

rule splunk-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "SPLUNK_HEC_TOKEN"
  MESSAGE "Blocked an unsafe pattern in splunk. Use the recommended best practices for 2025/2026."
}

rule splunk-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "splunkjs.Logger"
  MESSAGE "You are using an outdated API for splunk. Please upgrade to the newer API."
}
