# vault_write_safety.rules
# Technology: vault | Capability: write

rule vault-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "tls_disable = 1"
  MESSAGE "Blocked an unsafe pattern in vault. Use the recommended best practices for 2025/2026."
}

rule vault-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "vault_generic"
  MESSAGE "You are using an outdated API for vault. Please upgrade to the newer API."
}
